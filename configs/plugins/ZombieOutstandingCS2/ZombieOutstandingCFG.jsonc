  // ============================================================================
  // WEAPON BUY MENU
  // ============================================================================
  //
  //  Humans pick one primary and one secondary weapon from these lists at round
  //  start. DefaultGrenades are given automatically after the selection.
  //
  "ZOWeaponsCFG": {
    // Enable the weapon-selection menu system.
    "EnableWeaponsMenu":      true,
    // Open the weapon menu automatically for eligible humans at round start.
    "GiveMenuOnRoundStart":   true,
    // Allow players to reopen the weapon menu via command (once per round).
    "AllowOpenFromGameMenu":  true,
    // Reserve ammo given to each weapon chosen from the menu.
    "ReserveAmmoAmount":      9999,

    // -- Primary weapons ------------------------------------------------------
    "PrimaryWeapons": [
      { "Name": "AK-47",      "Classname": "weapon_ak47"          },
      { "Name": "M4A4",       "Classname": "weapon_m4a1"          },
      { "Name": "M4A1-S",     "Classname": "weapon_m4a1_silencer" },
      { "Name": "AWP",        "Classname": "weapon_awp"           },
      { "Name": "FAMAS",      "Classname": "weapon_famas"         },
      { "Name": "Galil AR",   "Classname": "weapon_galilar"       },
      { "Name": "SG 553",     "Classname": "weapon_sg556"         },
      { "Name": "AUG",        "Classname": "weapon_aug"           }
    ],

    // -- Secondary weapons ----------------------------------------------------
    "SecondaryWeapons": [
      { "Name": "Desert Eagle",  "Classname": "weapon_deagle"       },
      { "Name": "P250",          "Classname": "weapon_p250"         },
      { "Name": "USP-S",         "Classname": "weapon_usp_silencer" },
      { "Name": "Glock-18",      "Classname": "weapon_glock"        },
      { "Name": "Dual Berettas", "Classname": "weapon_elite"        }
    ],

    // -- Default grenades -----------------------------------------------------
    // Given automatically after secondary selection.
    // Valid classnames: weapon_hegrenade, weapon_flashbang,
    //                   weapon_smokegrenade, weapon_incgrenade, weapon_decoy
    "DefaultGrenades": [
      "weapon_hegrenade",
      "weapon_flashbang",
      "weapon_smokegrenade"
    ]
  },


  // ============================================================================
  // LASER TRIP MINES
  // ============================================================================
  //
  //  Mine fields:
  //    Enable              -- include this mine type in the mine menu.
  //    Name                -- display name shown in the mine menu.
  //    Model               -- server-side model path.
  //    CanExplorer         -- false = laser beam trap | true = explosive mine.
  //    CanOwnerTeamTrigger -- true = owner team can also trigger the mine.
  //    LaserRate           -- beam check interval in seconds.
  //    LaserDamage         -- damage per beam tick.
  //    LaserKnockBack      -- knockback per tick (beam mines only).
  //    ExplorerRadius      -- explosion radius in units (explosive mines only).
  //    ExplorerDamage      -- explosion damage (explosive mines only).
  //    Team                -- "ct", "t", or "all" (who can place this mine).
  //    Price               -- ammo packs cost per mine purchase.
  //    Limit               -- max simultaneous mines per player (0 = unlimited).
  //    Permissions         -- required Swiftly permission (empty = no restriction).
  //    GlowColor           -- mine entity glow "R,G,B,A".
  //    laserColor          -- beam colour "R,G,B,A".
  //    laserSize           -- beam visual thickness.
  //    MineOpenSound       -- sound played on placement.
  //    LaserOpenSound      -- sound when beam activates.
  //    LaserTouchSound     -- sound when beam is crossed.
  //    PrecacheSoundEvent  -- .vsndevts file to precache (workshop addon 3618032051).
  //    ModelAngleFix       -- degrees added to model yaw to correct orientation.
  //
  "ZOMineCFG": {
    "MineList": [
      {
        // Laser beam trap -- continuously damages players crossing the beam.
        "Enable":               true,
        "Name":                 "Laser Tripwire",
        "Model":                "models/stk_sentry_guns/lasermine/stk_lasermines_one.vmdl",
        "CanExplorer":          false,
        "CanOwnerTeamTrigger":  false,
        "LaserRate":            0.1,
        "LaserDamage":          10.0,
        "LaserKnockBack":       100.0,
        "ExplorerRadius":       360,
        "ExplorerDamage":       2600,
        "Team":                 "ct",
        "Price":                6,
        "Limit":                2,
        "Permissions":          "",
        "GlowColor":            "0,255,0,255",
        "laserColor":           "0,0,255,255",
        "laserSize":            1.0,
        "MineOpenSound":        "n4a_csdm_sentry.mine_set",
        "LaserOpenSound":       "n4a_csdm_sentry.mine_activate",
        "LaserTouchSound":      "n4a_csdm_sentry.elrocket_lghtning",
        "PrecacheSoundEvent":   "soundevents/n4a_csdm_sentry.vsndevts",
        "ModelAngleFix":        90.0
      },
      {
        // Explosive mine -- detonates when beam is crossed.
        "Enable":               true,
        "Name":                 "Explosive Mine",
        "Model":                "models/stk_sentry_guns/lasermine/stk_lasermines_two.vmdl",
        "CanExplorer":          true,
        "CanOwnerTeamTrigger":  false,
        "LaserRate":            0.1,
        "LaserDamage":          10.0,
        "LaserKnockBack":       100.0,
        "ExplorerRadius":       360,
        "ExplorerDamage":       2600,
        "Team":                 "ct",
        "Price":                10,
        "Limit":                2,
        "Permissions":          "",
        "GlowColor":            "255,0,0,255",
        "laserColor":           "255,0,0,255",
        "laserSize":            0.5,
        "MineOpenSound":        "n4a_csdm_sentry.mine_set",
        "LaserOpenSound":       "n4a_csdm_sentry.mine_activate",
        "LaserTouchSound":      "n4a_csdm_sentry.elrocket_lghtning",
        "PrecacheSoundEvent":   "soundevents/n4a_csdm_sentry.vsndevts",
        "ModelAngleFix":        0.0
