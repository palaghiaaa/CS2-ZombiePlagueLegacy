  // ── Weapon buy menu ──────────────────────────────────────────────────────
  "ZOWeaponsCFG": {
    // Enable the weapon selection menu system
    "EnableWeaponsMenu": true,
    // Show weapon menus to eligible humans at round start
    "GiveMenuOnRoundStart": true,
    // Allow players to re-open weapon menu via sw_buyweapons command (once per round)
    "AllowOpenFromGameMenu": true,
    // Reserve ammo given to each weapon chosen from the menu
    "ReserveAmmoAmount": 9999,
    // Primary weapon list shown in primary weapon menu
    "PrimaryWeapons": [
      { "Name": "AK-47",     "Classname": "weapon_ak47" },
      { "Name": "M4A4",      "Classname": "weapon_m4a1" },
      { "Name": "M4A1-S",    "Classname": "weapon_m4a1_silencer" },
      { "Name": "AWP",       "Classname": "weapon_awp" },
      { "Name": "FAMAS",     "Classname": "weapon_famas" },
      { "Name": "Galil AR",  "Classname": "weapon_galilar" },
      { "Name": "SG 553",    "Classname": "weapon_sg556" },
      { "Name": "AUG",       "Classname": "weapon_aug" }
    ],
    // Secondary weapon list shown in secondary weapon menu
    "SecondaryWeapons": [
      { "Name": "Desert Eagle", "Classname": "weapon_deagle" },
      { "Name": "P250",         "Classname": "weapon_p250" },
      { "Name": "USP-S",        "Classname": "weapon_usp_silencer" },
      { "Name": "Glock-18",     "Classname": "weapon_glock" },
      { "Name": "Dual Berettas","Classname": "weapon_elite" }
    ],
    // Default grenades given after secondary selection.
    // Supported classnames: weapon_hegrenade, weapon_flashbang, weapon_smokegrenade,
    //                       weapon_incgrenade, weapon_decoy
    "DefaultGrenades": [
      "weapon_hegrenade",
      "weapon_flashbang",
      "weapon_smokegrenade"
    ]
  },

  // ── Laser trip mines ─────────────────────────────────────────────────────
  "ZOMineCFG": {
    "MineList": [
      {
        // Laser beam trap – continuously damages players crossing the beam.
        "Enable": true,
        "Name": "Laser Tripwire",
        "Model": "models/stk_sentry_guns/lasermine/stk_lasermines_one.vmdl",
        // false = laser beam trap, true = explosive mine
        "CanExplorer": false,
        // false = only enemy players trigger, true = owner's team can also trigger
        "CanOwnerTeamTrigger": false,
        // Beam-trap settings (ignored when CanExplorer = true)
        "LaserRate": 0.1,
        "LaserDamage": 10.0,
        "LaserKnockBack": 100.0,
        // Explosive mine settings (ignored when CanExplorer = false)
        "ExplorerRadius": 360,
        "ExplorerDamage": 2600,
        // "all" = everyone, "ct" = CT only, "t" = T only
        "Team": "ct",
        // Purchase price in ammo packs
        "Price": 6,
        // Max simultaneous mines per player per type (0 = unlimited)
        "Limit": 2,
        // Required permission flag (empty = no restriction)
        "Permissions": "",
        // Glow outline "R,G,B,A" (empty = no glow)
        "GlowColor": "0,255,0,255",
        // Laser beam color "R,G,B,A"
        "laserColor": "0,0,255,255",
        // Laser beam visual width
        "laserSize": 1.0,
        // Sound events (requires workshop addon 3618032051)
        "MineOpenSound": "n4a_csdm_sentry.mine_set",
        "LaserOpenSound": "n4a_csdm_sentry.mine_activate",
        "LaserTouchSound": "n4a_csdm_sentry.elrocket_lghtning",
        "PrecacheSoundEvent": "soundevents/n4a_csdm_sentry.vsndevts",
        // Angle correction to fix model orientation (degrees)
        "ModelAngleFix": 90.0
      },
      {
        // Explosive laser mine – explodes when beam is touched.
        "Enable": true,
        "Name": "Explosive Mine",
        "Model": "models/stk_sentry_guns/lasermine/stk_lasermines_two.vmdl",
        "CanExplorer": true,
        "CanOwnerTeamTrigger": false,
        "LaserRate": 0.1,
        "LaserDamage": 10.0,
        "LaserKnockBack": 100.0,
        "ExplorerRadius": 360,
        "ExplorerDamage": 2600,
        "Team": "ct",
        "Price": 10,
        "Limit": 2,
        "Permissions": "",
        "GlowColor": "255,0,0,255",
        "laserColor": "255,0,0,255",
        "laserSize": 0.5,
        "MineOpenSound": "n4a_csdm_sentry.mine_set",
        "LaserOpenSound": "n4a_csdm_sentry.mine_activate",
        "LaserTouchSound": "n4a_csdm_sentry.elrocket_lghtning",
        "PrecacheSoundEvent": "soundevents/n4a_csdm_sentry.vsndevts",
        "ModelAngleFix": 0.0
      }
    ]
  }
