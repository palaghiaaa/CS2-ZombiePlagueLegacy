			"PlagueVox": "han.zombieplague.end.plague",
			"AssassinVox": "han.zombieplague.type.nemesis",
			"SniperVox": "han.zombieplague.type.survivor",
			"AVSVox": "han.zombieplague.type.nemesis",
			"HeroVox": "han.zombieplague.type.survivor",
			"HumanWinVox": "han.zombie.round.manhmwin",
			"ZombieWinVox": "han.zombie.round.manzbwin",
			"PrecacheSoundEvent": "soundevents/hanroundvoxs.vsndevts"
		},
		{
			"Name": "CSOL女性播报",
			"Enable": true,
			"RoundMusicVox": "han.zombie.round.class_startC,han.zombie.round.class_startD",
			"SecRemainVox": "han.zombie.round.fem20secremain",
			"CoundDownVox": "han.zombie.round.femcdone,han.zombie.round.femcdtwo,han.zombie.round.femcdthree,han.zombie.round.femcdfour,han.zombie.round.femcdfive,han.zombie.round.femcdsix,han.zombie.round.femcdseven,han.zombie.round.femcdeight,han.zombie.round.femcdnine,han.zombie.round.femcdten",
			"ZombieSpawnVox": "han.zombie.round.femzbcome",
			"NormalInfectionVox": "han.zombieplague.end.horror",
			"MultiInfectionVox": "han.zombieplague.end.horror",
			"NemesisVox": "han.zombieplague.type.nemesis",
			"SurvivorVox": "han.zombieplague.type.survivor",
			"SwarmVox": "han.zombieplague.end.horror",
			"PlagueVox": "han.zombieplague.end.plague",
			"AssassinVox": "han.zombieplague.type.nemesis",
			"SniperVox": "han.zombieplague.type.survivor",
			"AVSVox": "han.zombieplague.type.nemesis",
			"HeroVox": "han.zombieplague.type.survivor",
			"HumanWinVox": "han.zombie.round.femhmwin",
			"ZombieWinVox": "han.zombie.round.femzbwin",
			"PrecacheSoundEvent": "soundevents/hanzbplayers.vsndevts"
		},
		{
			"Name": "HL1男性播报",
