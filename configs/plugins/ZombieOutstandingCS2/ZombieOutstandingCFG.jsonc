{
  // ════════════════════════════════════════════════════════════════════════════
  // ZOMBIE OUTSTANDING — MAIN CONFIGURATION
  // ════════════════════════════════════════════════════════════════════════════

  // ── Core / game-play settings ────────────────────────────────────────────
  "ZOMainCFG": {

	// ── Round timing ─────────────────────────────────────────────────────────
	// Seconds players have to prepare before infection starts.
	"RoundReadyTime": "22.0",
	// Round duration in minutes.
	"RoundTime": "4.0",

	// ── Game modes ───────────────────────────────────────────────────────────
	// Weight controls how often a mode is randomly chosen (higher = more frequent).
	"NormalInfection":
	{
		"Enable": true,
		"Name": "Infection Mode",
		"MotherZombieNames": "Mother Zombie",
		"MotherZombieCount": 1,
		"Weight": 50,
		// Minimum connected (non-bot) players for this mode to be eligible.
		"MinPlayers": 0,
		"EnableInfiniteClipMode": false,
		"ZombieCanReborn": false
	},
	"MultiInfection":
	{
		"Enable": true,
		"Name": "Multi Infection Mode",
		"MotherZombieNames": "Mother Zombie",
		"MotherZombieCount": 5,
		"Weight": 50,
		// Minimum connected (non-bot) players for this mode to be eligible.
		"MinPlayers": 0,
		"EnableInfiniteClipMode": true,
		"ZombieCanReborn": true
	},
	"Nemesis":
	{
		"Enable": true,
		"Name": "Nemesis Mode",
		"NemesisNames": "Nemesis",
		"Weight": 50,
		// Minimum connected (non-bot) players for this mode to be eligible.
		// Set to 0 to impose no minimum.
		"MinPlayers": 0,
		// HP assigned to the Nemesis at round start.
		// Balance rationale (round = 4 min, human weapon DPS ~270 effective):
		//   5 humans  → ~60 s to kill  (half the round — fair for small servers)
		//   10 humans → ~29 s to kill  (rewards coordination on full servers)
		// The 100 HP/s regen adds ~6 000 extra effective HP over a sustained fight.
		// Set to 0 to fall back to the special-class HP in ZOSpecialClassCFG.
		"NemesisHealth": 75000,
		"EnableInfiniteClipMode": true,
		// Zombies do NOT respawn in Nemesis mode — the single Nemesis must survive alone.
		"ZombieCanReborn": false
	},
	"Survivor":
	{
		"Enable": true,
		"Name": "Survivor Mode",
		"Weight": 50,
		// Minimum connected (non-bot) players for this mode to be eligible.
		"MinPlayers": 0,
		"SurvivorNames": "Survivor",
		// HP assigned to the Survivor when it spawns. 8 000 HP lets one human
		// endure sustained zombie pressure for most of the round without being
		// unkillable. Set to 0 to use human base HP.
		"SurvivorHealth": 8000,
		"SurvivorSpeed": 0.92,
		"SurvivorGravity": 1.25,
		"SurvivorDamage": 5.0,
		"SurvivorWeapon": "weapon_xm1014",
		"CustomWeaponName": "Survivor XM1014",
		"ModelsPath": "characters/models/tm_phoenix_heavy/tm_phoenix_heavy.vmdl",
		"EnableInfiniteClipMode": false,
		// Zombies do NOT respawn in Survivor mode — eliminating all zombies is a win path.
		"ZombieCanReborn": false
	},
	"Swarm":
	{
		"Enable": true,
		"Name": "Swarm Mode",
		"Weight": 50,
		// Minimum connected (non-bot) players for this mode to be eligible.
		"MinPlayers": 0,
		"EnableInfiniteClipMode": true,
		// Zombies do NOT respawn in Swarm mode — humans win by eliminating all zombies.
		"ZombieCanReborn": false
	},
	"Plague":
	{
		"Enable": true,
		"Name": "Plague Mode",
		"Weight": 50,
		// Minimum connected (non-bot) players for this mode to be eligible.
		"MinPlayers": 0,
		"NemesisNames": "Nemesis",
		"SurvivorNames": "Survivor",
		// Number of Nemesis promoted in Plague mode (mirrors zp_plague_nem_number).
		"NemesisCount": 1,
		// Number of Survivors appointed in Plague mode (mirrors zp_plague_surv_number).
		"SurvivorCount": 1,
		// HP multiplier for Nemesis in this mode (1.0 = full HP, 0.5 = half HP / Armageddon style).
		// Mirrors zp_lnj_nem_hp_multi from ZombiePlague CS 1.6 Armageddon mode.
		"NemesisHPMultiplier": 1.0,
		// HP multiplier for Survivors in this mode (1.0 = full HP, 0.5 = half HP / Armageddon style).
		// Mirrors zp_lnj_surv_hp_multi from ZombiePlague CS 1.6 Armageddon mode.
		"SurvivorHPMultiplier": 1.0,
		"EnableInfiniteClipMode": true,
		// Zombies do NOT respawn in Plague mode — the Nemesis(es) must eliminate all humans alone.
		"ZombieCanReborn": false
	},
	"Assassin":
	{
		"Enable": true,
		"Name": "Assassin Mode",
		"Weight": 50,
		// Minimum connected (non-bot) players for this mode to be eligible.
		"MinPlayers": 0,
		"AssassinNames": "Assassin",
		// HP assigned to the Assassin when it spawns. 24 000 HP places it
		// between a normal zombie and the Nemesis — dangerous enough to be a
		// real threat, but killable by two coordinated players.
		// Set to 0 to use the special-class default HP in ZOSpecialClassCFG.
		"AssassinHealth": 24000,
		// Distance (units) within which the Assassin becomes visible to humans.
		"InvisibilityDist": 200.0,
		"EnableInfiniteClipMode": false,
		// Zombies do NOT respawn in Assassin mode — the Assassin wins by eliminating all humans.
		"ZombieCanReborn": false
	},
	"Sniper":
	{
		"Enable": true,
		"Name": "Sniper Mode",
		"Weight": 50,
		// Minimum connected (non-bot) players for this mode to be eligible.
		"MinPlayers": 0,
		"SniperNames": "Sniper",
		// HP assigned to the Sniper when it spawns. 5 000 HP is intentionally
		// lower than the Survivor — glass-cannon role: extreme damage output but
		// dies quickly if zombies close the gap. Set to 0 to use human base HP.
		"SniperHealth": 5000,
		"SniperSpeed": 0.92,
		"SniperGravity": 0.75,
		"SniperDamage": 35.0,
		// When true, a single sniper shot instantly kills any zombie (CS 1.6 style).
		// When false, damage is multiplied by SniperDamage instead.
		"OneShotKill": true,
		"SniperWeapon": "weapon_awp",
		"CustomWeaponName": "Sniper AWP",
		"ModelsPath": "characters/models/tm_professional/tm_professional_varf4.vmdl",
		"EnableInfiniteClipMode": false,
		// Zombies do NOT respawn in Sniper mode — the Sniper wins by eliminating all zombies.
		"ZombieCanReborn": false
	},
	"AVS":
	{
		"Enable": true,
		"Name": "Assassin vs Sniper",
		"Weight": 50,
		// Minimum connected (non-bot) players for this mode to be eligible.
		"MinPlayers": 0,
		"AssassinNames": "Assassin",
		"SniperNames": "Sniper",
		"EnableInfiniteClipMode": true,
		// Zombies do NOT respawn in AVS mode — eliminating the opposing special role wins.
		"ZombieCanReborn": false
	},
	"Hero":
	{
		"Enable": true,
		"Name": "Hero Mode",
		"Weight": 50,
		// Minimum connected (non-bot) players for this mode to be eligible.
		"MinPlayers": 0,
		"HeroCount": 3,
		"HeroNames": "Hero",
		"HeroHealth": 1500,
		"HeroSpeed": 3.0,
		"HeroGravity": 0.4,
		"HeroDamage": 50.0,
		"ModelsPath": "characters/models/ctm_heavy/ctm_heavy.vmdl",
		"EnableInfiniteClipMode": false,
		// Zombies CAN respawn in Hero mode — heroes must hold out against endless pressure.
		"ZombieCanReborn": true
	},

	// ── Round scheduling ─────────────────────────────────────────────────────
	// Minimum consecutive Normal-Infection rounds required before a special
	// game mode (Nemesis, Survivor, etc.) can be randomly chosen.
	// Set to 0 to disable the restriction (pure weight-based selection).
	// Example: 2 = at least 2 normal rounds must pass between special rounds.
	"NormalRoundsInterval": 5,

	// ── Solo / low-population guard ──────────────────────────────────────────
	// Minimum number of alive human players required before infection starts.
	// The check is: if (humanCandidates < MinPlayersForInfection) → skip infection.
	//
	// WHY YOU NEED 2 (NOT 1) TO PROTECT A SOLO PLAYER:
	//   With 1 human and this set to 1:  1 < 1 = false  → infection runs →
	//     solo player becomes zombie → humanCount=0 → FakeZombieWins → round ends
	//     immediately. Setting to 1 is identical to having no guard at all.
	//   With 1 human and this set to 2:  1 < 2 = true   → infection is skipped →
	//     round runs to the natural timer end. ✓
	//   With 2 humans and this set to 2: 2 < 2 = false  → infection runs normally. ✓
	//
	// Recommended: 2 (protects solo / test sessions while normal multi-player
	// rounds are completely unaffected).
	"MinPlayersForInfection": 2,

	// ── Mother zombie HP multiplier ───────────────────────────────────────────
	// HP multiplier applied to the first (mother) zombie each round.
	// 2.5 = the mother zombie gets 2.5× the normal zombie class HP.
	// Mirrors zp_zombie_first_hp from ZombiePlague CS 1.6 (their default was 2.0).
	// Set to 1.0 to disable (mother zombie gets normal HP).
	"MotherZombieHPMultiplier": 2.5,

	// ── Human settings ───────────────────────────────────────────────────────
	"HumandefaultModel": "characters/models/ctm_st6/ctm_st6_variante.vmdl",
	"HumanMaxHealth": 150,
	// Show a damage HUD indicator when a human damages a zombie.
	"EnableDamageHud": true,
	// Show a status HUD with game mode, player class, and ammo packs every 1 second.
	"EnableStatusHud": true,
	"HumanInitialSpeed": 1.0,
	"HumanInitialGravity": 1.0,

	// ── Knockback multipliers ────────────────────────────────────────────────
	// Multipliers applied to bullet knockback force depending on hit location / state.
	"HumanKnockBackHeadMultiply": 2.0,
	"HumanKnockBackBodyMultiply": 1.0,
	"HumanKnockBackGroundMultiply": 1.0,
	"HumanKnockBackAirMultiply": 0.5,
	// Extra multiplier applied when a Hero shoots a zombie.
	"HumanHeroKnockBackMultiply": 1.0,

	// ── Weapon settings ──────────────────────────────────────────────────────
	"EnableInfiniteReserveAmmo": true,
	"EnableWeaponNoRecoil": true,

	// ── Spawn points ─────────────────────────────────────────────────────────
	// Comma-separated spawn-point types to use. Valid values: CT, T, DM.
	"HumanSpawnPoints": "CT,T,DM",
	"ZombieSpawnPoints": "CT,T,DM",

	// ── Zombie physics ───────────────────────────────────────────────────────
	// Base knockback force (units/s) applied to a zombie when shot.
	// Used for weapons not listed in WeaponKnockbackTable below.
	"KnockZombieForce": 200.0,
	// Duration (seconds) a zombie is stunned / slowed after a knockback hit.
	"StunZombieTime": 0.1,

	// ── Per-weapon knockback table ────────────────────────────────────────────
	// Maps each weapon's designer name to its individual knockback force.
	// Weapons NOT listed here use KnockZombieForce as the fallback.
	// Set a value to 0 to disable knockback for that weapon entirely.
	// Values are intentionally moderate — scale up if you want more push.
	// Based on ZombiePlague 1.6 relative ratios, adapted for CS2.
	"WeaponKnockbackTable": {
		"weapon_awp":        350.0,   // Sniper rifle — highest single-shot impact
		"weapon_ssg08":      300.0,   // Scout / SSG 08 — lighter sniper
		"weapon_xm1014":     280.0,   // Shotgun — close-range blast
		"weapon_nova":       280.0,   // Shotgun
		"weapon_sawedoff":   270.0,   // Sawed-off
		"weapon_mag7":       270.0,   // MAG-7
		"weapon_m249":       260.0,   // LMG — heavy sustained fire
		"weapon_negev":      260.0,   // Negev LMG
		"weapon_ak47":       240.0,   // AK-47 — strong rifle
		"weapon_sg553":      235.0,   // SG 553
		"weapon_aug":        230.0,   // AUG
		"weapon_m4a1":       225.0,   // M4A1-S
		"weapon_m4a4":       225.0,   // M4A4
		"weapon_famas":      220.0,   // FAMAS
		"weapon_galilar":    220.0,   // Galil AR
		"weapon_deagle":     210.0,   // Desert Eagle — powerful pistol
		"weapon_revolver":   200.0,   // R8 Revolver
		"weapon_usp_silencer": 160.0, // USP-S
		"weapon_hkp2000":    150.0,   // P2000
		"weapon_glock":      140.0,   // Glock-18
		"weapon_p250":       145.0,   // P250
		"weapon_tec9":       140.0,   // Tec-9
		"weapon_cz75a":      140.0,   // CZ75-Auto
		"weapon_fiveseven":  145.0,   // Five-SeveN
		"weapon_elite":      130.0,   // Dual Berettas
		"weapon_p90":        120.0,   // P90 — high fire rate, low per-shot push
		"weapon_bizon":      110.0,   // PP-Bizon
		"weapon_mac10":      110.0,   // MAC-10
		"weapon_mp9":        115.0,   // MP9
		"weapon_mp5sd":      115.0,   // MP5-SD
		"weapon_mp7":        115.0,   // MP7
		"weapon_ump45":      120.0,   // UMP-45
		"weapon_knife":        0.0    // Knife — infection handled separately, no push
	},

	// ── Spawn protection ─────────────────────────────────────────────────────
	// Seconds of invulnerability granted to every player immediately after spawn.
	// Set to 0 to disable. Mirrors zp_spawn_protection from ZombiePlague CS 1.6.
	"SpawnProtectionTime": 2.0,

	// ── Zombie infection health reward ───────────────────────────────────────
	// HP given to a zombie attacker each time they successfully infect a human.
	// Capped at the zombie's MaxHealth. Set to 0 to disable.
	// Mirrors zp_zombie_infect_health from ZombiePlague CS 1.6.
	"ZombieInfectHealthReward": 500,

	// ── Zombie leap (Long Jump) ───────────────────────────────────────────────
	// When enabled, a zombie that presses Jump while on the ground receives a
	// burst of horizontal + vertical velocity, letting them leap forward.
	// Mirrors the zp_leap_* family of cvars from ZombiePlague CS 1.6.

	// Regular zombie leap
	"LeapZombiesEnabled": true,
	"LeapZombiesForce": 500.0,      // Horizontal impulse (units/s)
	"LeapZombiesHeight": 300.0,     // Vertical impulse added to the jump (units/s)
	"LeapZombiesCooldown": 1.5,     // Seconds between consecutive leaps

	// Nemesis leap (stronger — mirrors zp_leap_nemesis_force / _height)
	"LeapNemesisEnabled": true,
	"LeapNemesisForce": 1000.0,
	"LeapNemesisHeight": 700.0,
	"LeapNemesisCooldown": 2.0,

	// Assassin leap (mirrors zp_leap_assassin_force / _height)
	"LeapAssassinEnabled": true,
	"LeapAssassinForce": 700.0,
	"LeapAssassinHeight": 650.0,
	"LeapAssassinCooldown": 1.5,

	// ── T-Virus / Vaccine ────────────────────────────────────────────────────
	"TVaccineSound": "HealthShot.Pickup",
	// Radius (units) of the T-Virus grenade infection cloud.
	"TVirusGrenadeRange": 300.0,
	// Whether the T-Virus grenade can infect Hero-class players.
	"TVirusCanInfectHero": true,
	"TVirusGrenadeSound": "han.zombieplague.grenadedote",
	// Sound played when a player receives bonus health (e.g. from an item).
	"AddHealthSound": "HealthShot.Pickup",

	// ── Fire grenade ─────────────────────────────────────────────────────────
	"FireGrenade": true,
	// Give humans a fire (HE) grenade on spawn.
	"SpawnGiveFireGrenade": true,
	// Give humans an incendiary grenade on spawn (in addition to the fire grenade).
	"SpawnGiveIncGrenade": false,
	"FireGrenadeRange": 300.0,
	"FireGrenadeDmg": 500.0,
	// Damage per tick while a zombie is burning.
	"FireDmg": 10.0,
	"FireGrenadeDuration": 5.0,
	"FireGrenadeSound": "han.zombieplague.grenadedote",

	// ── Light grenade ────────────────────────────────────────────────────────
	"LightGrenade": true,
	// Give humans a flashbang (light grenade) on spawn.
	"SpawnGiveLightGrenade": true,
	// Illumination radius (units).
	"LightGrenadeRange": 1000.0,
	// Duration (seconds) the light stays active.
	"LightGrenadeDuration": 30.0,
	"LightGrenadeSound": "C4.ExplodeTriggerTrip",

	// ── Freeze grenade ───────────────────────────────────────────────────────
	"FreezeGrenade": true,
	// Give humans a smoke (freeze grenade) on spawn.
	"SpawnGiveFreezeGrenade": true,
	"FreezeGrenadeRange": 300.0,
	// Duration (seconds) a zombie remains frozen.
	"FreezeGrenadeDuration": 10.0,
	"FreezeGrenadeSound": "han.zombieplague.grenadedote",

	// ── Teleport grenade ─────────────────────────────────────────────────────
	"TelportGrenade": true,
	// Give humans a teleport grenade on spawn.
	"SpawnGiveTelportGrenade": false,

	// ── SCBA Suit ────────────────────────────────────────────────────────────
	"CanUseScbaSuit": true,
	"ScbaSuitGetSound": "Player.PickupPistol",
	"ScbaSuitBrokenSound": "Breakable.Flesh",

	// ── Commands ─────────────────────────────────────────────────────────────
	// Client commands registered by the plugin (can be changed freely).
	"ZombieClassCommand": "sw_zclass",
	"AdminMenuItemCommand": "sw_zadmin",
	"MainMenuCommand": "sw_zmenu",
	"ExtraItemsCommand": "sw_zextra",
	"BuyWeaponsCommand": "sw_buyweapons",
	// Command to open the mine selection menu (must start with sw_)
	"MineMenuCommand": "sw_mine",
	// Leave empty ("") to allow everyone to open the admin menu.
	// Use comma-separated Swiftly permission strings to restrict access.
	"AdminMenuPermission": "hzp.adminmenu",

	// ── Ambient sound ────────────────────────────────────────────────────────
	// Comma-separated sound events played in rotation during the round.
	"AmbSound": "han.zombie.amb.zriot,han.zombie.amb.classicA,han.zombie.amb.classicB,han.zombie.amb.classicC,han.zombie.amb.classicD",
	// Interval in seconds between ambient sound plays.
	"AmbSoundLoopTime": "60.0",
	"AmbSoundVolume": "0.8",
	// Comma-separated .vsndevts files to precache for ambient sounds.
	"PrecacheAmbSound": "soundevents/hanzbambience.vsndevts,soundevents/hanzombiepanicplayer.vsndevts",

	// ── Chat / debug settings ────────────────────────────────────────────────
	// Prefix prepended to all plugin chat messages.
	"ChatPrefix": "[red][INFO][default]",
	// Log command invocations to the server console.
	"EnableCommandDebugLogs": false,
	// Send a chat reply to the invoking player on each command invocation.
	"EnableCommandDebugChatReply": false,

	// ── Economy (Ammo Packs) ─────────────────────────────────────────────────
	// Wallet kind name registered in the Economy plugin.
	// Must match a wallet kind configured in Economy's config.
	"EconomyWalletKind": "ammo",

	// ── Fog ──────────────────────────────────────────────────────────────────
	// Server-wide fog applied automatically on map load and to every spawning
	// player. Set "Enable" to false to disable completely.
	// ColorR/G/B: fog colour components (0-255).
	//   Default: dark grey-green (100, 110, 100) – zombie horror atmosphere.
	// StartDist : distance (game units) at which fog begins (default 128 – very close).
	// EndDist   : distance at which fog reaches full density (default 2048).
	// MaxDensity: opacity at EndDist (0.0 – 1.0, default 0.9 – heavy).
	// Exponent  : fall-off curve (1.0 = linear).
	"Fog": {
		"Enable": true,
		"ColorR": 100,
		"ColorG": 110,
		"ColorB": 100,
		"StartDist": 128.0,
		"EndDist": 2048.0,
		"MaxDensity": 0.9,
		"Exponent": 1.0
	},

	// ── Skybox ───────────────────────────────────────────────────────────────
	// Override the map's skybox on every map load.
	// Provide a sky name as used by sv_skyname, e.g. "sky_csgo_cloudy01".
	// Leave empty ("") to keep the map's default skybox.
	// Recommended zombie-mode skies (overcast / night / apocalyptic):
	//   "sky_overcast01", "sky_csgo_night02", "sky_csgo_cloudy01"
	"Skybox": "sky_csgo_cloudy01"
  },

  // ── Vox / round sound groups ─────────────────────────────────────────────
  "ZOVoxCFG": {
    "VoxList": [
		{
			"Name": "CSOL男性播报",
			"Enable": true,
